# =============================================================================
# servlitcys — modelo de .env (copiar para .env e preencher segredos)
# cp .env.example .env && php artisan key:generate
# =============================================================================

APP_NAME=SERVLITCYS
APP_ENV=production
APP_KEY=
APP_DEBUG=false
APP_URL=https://seu-dominio.exemplo.br
APP_TIMEZONE=America/Sao_Paulo
APP_LOCALE=pt_BR
APP_FALLBACK_LOCALE=pt_BR
APP_FAKER_LOCALE=pt_BR
APP_MAINTENANCE_DRIVER=file
BCRYPT_ROUNDS=12
CHART_EXPORT_AUTHOR=

LOG_CHANNEL=stack
LOG_STACK=daily
LOG_DEPRECATIONS_CHANNEL=null
LOG_LEVEL=warning
LOG_DAILY_DAYS=14

DB_CONNECTION=mysql
DB_HOST=127.0.0.1
DB_PORT=3306
DB_DATABASE=servlitcys
DB_USERNAME=servlitcys
DB_PASSWORD=

ADMIN_EMAIL=admin@exemplo.local
ADMIN_USERNAME=admin
ADMIN_PASSWORD=alterar-antes-do-seed
ADMIN_BIRTH_DATE=1990-01-01
ADMIN_CPF=

SERVENTEC_WHATSAPP_NUMBER=

SESSION_DRIVER=database
SESSION_LIFETIME=120
SESSION_ENCRYPT=true
SESSION_PATH=/
SESSION_DOMAIN=null
SESSION_SECURE_COOKIE=true
SESSION_SAME_SITE=lax

BROADCAST_CONNECTION=log
FILESYSTEM_DISK=local
QUEUE_CONNECTION=database
CACHE_STORE=database

REDIS_CLIENT=phpredis
REDIS_HOST=127.0.0.1
REDIS_PASSWORD=null
REDIS_PORT=6379

MAIL_MAILER=smtp
MAIL_HOST=
MAIL_PORT=587
MAIL_USERNAME=
MAIL_PASSWORD=
MAIL_FROM_ADDRESS=noreply@exemplo.br
MAIL_FROM_NAME="${APP_NAME}"

AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
AWS_DEFAULT_REGION=us-east-1
AWS_BUCKET=
AWS_USE_PATH_STYLE_ENDPOINT=false

VITE_APP_NAME="${APP_NAME}"

ANALYTICS_LAZY_TABS=true
# false = carrega todas as abas no HTML inicial (modo antigo; mais lento)
ANALYTICS_INDEX_FUNDING_CONTEXT=false
# true = executa resumo Discrepâncias ao «Aplicar filtros» (pode causar timeout)
ANALYTICS_FUNDEB_DISC_SUMMARY=true
ANALYTICS_FUNDING_SUMMARY_CACHE=600
ANALYTICS_PDF_QUEUE=default
ANALYTICS_PDF_JOB_TIMEOUT=900
ANALYTICS_PDF_TRIES=2
ANALYTICS_PDF_DISK=local
ANALYTICS_PDF_MAX_PER_USER=10
ANALYTICS_PDF_SERVENTEC_NAME="Serventec Assessoria"
ANALYTICS_PDF_SERVENTEC_URL=https://serventec.com.br
ANALYTICS_PDF_REGIONAL_IMAGE=images/pdf/regional
ANALYTICS_PDF_MAP_ZOOM=9

APP_NOTIFICATIONS_ENABLED=true
APP_NOTIFICATIONS_POLL_SECONDS=45
APP_NOTIFICATIONS_INDEX_LIMIT=25
APP_NOTIFICATIONS_QUEUE=default

IEDUCAR_DISC_VAA_REFERENCIA=4500
IEDUCAR_FUNDEB_NATIONAL_FLOOR=true
IEDUCAR_FUNDEB_NATIONAL_VAAF_2025=
IEDUCAR_FUNDEB_JSON_URL=storage://app/fundeb/api/{ibge}/{ano}.json
IEDUCAR_FUNDEB_CKAN_URL=https://www.fnde.gov.br/dadosabertos
IEDUCAR_FUNDEB_CKAN_RESOURCE_ID=
IEDUCAR_FUNDEB_CKAN_SEARCH="fundeb vaaf municipio"
IEDUCAR_FUNDEB_API_TIMEOUT=30

IEDUCAR_MATRICULA_INDICADORES_INCLUIR_SITUACAO_INEP=true
IEDUCAR_MATRICULA_SITUACAO_INEP_ATIVAS=1

IEDUCAR_OTHER_FUNDING_PUBLIC_QUERIES=true
IEDUCAR_OTHER_FUNDING_PUBLIC_CACHE_TTL=3600
IEDUCAR_OTHER_FUNDING_PUBLIC_TIMEOUT=12
IEDUCAR_OTHER_FUNDING_LIVE_FNDE=true
PORTAL_TRANSPARENCIA_API_KEY=
IEDUCAR_PORTAL_TRANSPARENCIA_ENABLED=true
IEDUCAR_TESOURO_CKAN_ENABLED=true
IEDUCAR_TESOURO_TRANSFERENCIAS_RESOURCE_ID=
# docs/CONSULTAS_EXTERNAS.md — detalhe das consultas na aba Financiamentos

IEDUCAR_WORK_EXCLUDE_LOGINS=admin,administrador,suporte,portabilis
IEDUCAR_WORK_EXCLUDE_USER_IDS=1
IEDUCAR_WORK_EXCLUDE_NIVEL=1
IEDUCAR_WORK_MINUTES_PER_RECORD=3.5
IEDUCAR_WORK_HOURS_PER_DAY=6

SCHEDULE_RUN_INTERVAL_MINUTES=3

ADMIN_SYNC_QUEUE=admin-sync
ADMIN_SYNC_JOB_TIMEOUT=3600
ADMIN_SYNC_SCHEDULE_ENABLED=true
ADMIN_SYNC_SCHEDULE_INTERVAL_MINUTES=60
ADMIN_SYNC_SCHEDULE_MAX_SECONDS=3300
ADMIN_SYNC_SCHEDULE_OVERLAP_MINUTES=65

PULSE_ENABLED=true
PULSE_PATH=pulse
PULSE_STORAGE_DRIVER=database
PULSE_DB_CONNECTION=mysql
PULSE_INGEST_DRIVER=storage
PULSE_SCHEDULE_ENABLED=true
PULSE_SCHEDULE_INTERVAL_MINUTES=3
PULSE_SCHEDULE_DIGEST_TICK=true
PULSE_SLOW_QUERIES_THRESHOLD=500
PULSE_SLOW_REQUESTS_THRESHOLD=1000
PULSE_SLOW_OUTGOING_REQUESTS_THRESHOLD=750

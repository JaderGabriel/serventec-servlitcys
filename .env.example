# =============================================================================
# servlitcys — MODELO para desenvolvimento / instalação nova
# =============================================================================
#
#   Desenvolvimento:  cp .env.example .env && php artisan key:generate
#
#   PRODUÇÃO: edite apenas o ficheiro .env no servidor.
#   Lista completa: docs/VARIAVEIS_AMBIENTE.md
#
#   Após alterar .env:  php artisan config:clear && php artisan storage:link
#
#   Cron:  */3 * * * * cd /caminho/servlitcys && php artisan schedule:run
#   Filas: php artisan queue:work database --queue=default,admin-sync --sleep=3 --tries=3
# =============================================================================

# --- Aplicação ---
APP_NAME=SERVLITCYS
APP_ENV=production
APP_KEY=
APP_DEBUG=false
APP_URL=https://seu-dominio.exemplo.br
APP_TIMEZONE=America/Sao_Paulo
APP_LOCALE=pt_BR
APP_FALLBACK_LOCALE=pt_BR
APP_FAKER_LOCALE=pt_BR
APP_MAINTENANCE_DRIVER=file
BCRYPT_ROUNDS=12
CHART_EXPORT_AUTHOR=

# --- Legal / privacidade (LGPD) ---
LEGAL_PRIVACY_LAST_UPDATED=2026-05-25
LEGAL_PRIVACY_VERSION=2026-05-25
LEGAL_COOKIES_VERSION=2026-05-25
LEGAL_REQUIRE_AUTHENTICATED_CONSENT=true
# LEGAL_PRIVACY_CONTACT_EMAIL=privacidade@exemplo.br
# Documentos legais editáveis em /admin/documentos-legais (versões na tabela legal_document_versions).

# --- Logs ---
LOG_CHANNEL=stack
LOG_STACK=daily
LOG_DEPRECATIONS_CHANNEL=null
LOG_LEVEL=warning
LOG_DAILY_DAYS=14

# --- Base de dados principal (Laravel) ---
DB_CONNECTION=mysql
DB_HOST=127.0.0.1
DB_PORT=3306
DB_DATABASE=servlitcys
DB_USERNAME=servlitcys
DB_PASSWORD=

# --- Administrador inicial (primeira instalação / db:seed) ---
ADMIN_EMAIL=admin@exemplo.local
ADMIN_USERNAME=admin
ADMIN_PASSWORD=alterar-antes-do-seed
ADMIN_BIRTH_DATE=1990-01-01
ADMIN_CPF=

# Senha padrão i-Educar (opcional): só para php artisan cities:reencrypt-db-passwords
# CITIES_DB_DEFAULT_PASSWORD=

# --- Serventec (landing) ---
#SERVENTEC_WHATSAPP_NUMBER=

# --- Sessão ---
# Produção com Redis: SESSION_DRIVER=redis (menos I/O MySQL no login)
SESSION_DRIVER=database
SESSION_LIFETIME=120
SESSION_ENCRYPT=true
SESSION_PATH=/
SESSION_DOMAIN=null
SESSION_SECURE_COOKIE=true
SESSION_SAME_SITE=lax

# --- Cache, filas ---
BROADCAST_CONNECTION=log
FILESYSTEM_DISK=local
# Produção com Redis: QUEUE_CONNECTION=redis + worker redis (ver docs/PERFORMANCE.md)
QUEUE_CONNECTION=database
DB_QUEUE=default
# Opcional: se vazio, usa max(ADMIN_SYNC_JOB_TIMEOUT, ANALYTICS_PDF_JOB_TIMEOUT) + 120 s
# DB_QUEUE_RETRY_AFTER=3720
# Produção com Redis: CACHE_STORE=redis (rate-limit do login, Cache::remember, etc.)
CACHE_STORE=database

# --- Redis (recomendado em produção) ---
# Servidores sem extensão phpredis: use predis (já incluído no Composer).
REDIS_CLIENT=predis
REDIS_HOST=127.0.0.1
REDIS_PASSWORD=null
REDIS_PORT=6379
# Com Redis activo, considere também:
# PULSE_CACHE_DRIVER=redis
# PULSE_INGEST_DRIVER=redis

# --- Performance (código; ver config/performance.php e docs/PERFORMANCE.md) ---
PERFORMANCE_DEFER_LOGIN_AUDIT=true
PERFORMANCE_SKIP_MAIL_ON_AUTH=true
PERFORMANCE_USER_CITY_IDS_CACHE=3600
PERFORMANCE_MAIL_SETTINGS_CACHE=3600
PERFORMANCE_PULSE_SKIP_AUTH=true

# Diagnóstico SQL no Pulse (base sistema + bases i-Educar por município)
PULSE_DB_DIAGNOSTICS_ENABLED=true
PULSE_DB_DIAGNOSTICS_SLOW_MS=300
PULSE_DB_DIAGNOSTICS_SLOW_RUN_MS=1500
PULSE_OPERATIONS_ENABLED=true
PULSE_OPERATIONS_SLOW_MS=750
PULSE_OPERATIONS_HTTP=true

# --- E-mail (ou painel Admin → Configurações de e-mail) ---
MAIL_MAILER=smtp
MAIL_SCHEME=null
MAIL_HOST=
MAIL_PORT=587
MAIL_USERNAME=
MAIL_PASSWORD=
MAIL_ENCRYPTION=tls
MAIL_FROM_ADDRESS=noreply@exemplo.br
MAIL_FROM_NAME="${APP_NAME}"

# --- AWS (opcional) ---
AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
AWS_DEFAULT_REGION=us-east-1
AWS_BUCKET=
AWS_USE_PATH_STYLE_ENDPOINT=false

VITE_APP_NAME="${APP_NAME}"

# --- Documentação admin (links GitHub) ---
DOCS_GITHUB_REPOSITORY=https://github.com/JaderGabriel/serventec-servlitcys
DOCS_GITHUB_BRANCH=main

# --- Notificações ---
APP_NOTIFICATIONS_ENABLED=true
APP_NOTIFICATIONS_POLL_SECONDS=45
APP_NOTIFICATIONS_INDEX_LIMIT=40
APP_NOTIFICATIONS_QUEUE=default
APP_NOTIFICATIONS_DEDUPE_MINUTES=360
APP_NOTIFICATIONS_OPERATIONAL=true
APP_NOTIFICATIONS_OPERATIONAL_SCHEDULE=true
APP_NOTIFICATIONS_OPERATIONAL_INTERVAL_MINUTES=15
APP_NOTIFICATIONS_SYNC_FAIL_THRESHOLD=1
APP_NOTIFICATIONS_PDF_STALE_HOURS=2
APP_NOTIFICATIONS_QUEUE_PENDING_THRESHOLD=25
APP_NOTIFICATIONS_ANALYTICS_ERRORS=true

# Verificação diária de fontes oficiais (public-data:check-official)
PUBLIC_DATA_DAILY_CHECK_ENABLED=true
PUBLIC_DATA_DAILY_CHECK_SCHEDULE=true
PUBLIC_DATA_DAILY_CHECK_TIME=07:00
PUBLIC_DATA_DAILY_CHECK_HTTP_TIMEOUT=12

# Monitor de módulos — recolha periódica de sondas (module-monitor:collect)
MODULE_MONITOR_ENABLED=true
MODULE_MONITOR_COLLECT_SCHEDULE_ENABLED=true
MODULE_MONITOR_COLLECT_INTERVAL_MINUTES=10
# MODULE_MONITOR_COLLECT_OVERLAP_MINUTES=8

# --- Horizonte (mapa oportunidade municipal) ---
HORIZONTE_ENABLED=true
HORIZONTE_CACHE_SECONDS=900
# Exercício FUNDEB/Censo/SAEB (vazio ou inválido = ano civil anterior, ex. 2025 em 2026)
# HORIZONTE_REFERENCE_YEAR=2025
HORIZONTE_HIGH_THRESHOLD=70
HORIZONTE_MEDIUM_THRESHOLD=40
# Gráfico de matrículas no modal (prospectos sem Consultoria) — anos da série Censo
# HORIZONTE_ENROLLMENT_SERIES_YEARS=5
# Fase Educacenso — importação multi-ano para o gráfico (1 ano por passo por defeito)
# HORIZONTE_EDUCACENSO_ENABLED=true
# HORIZONTE_EDUCACENSO_FETCH_IF_MISSING=true
# HORIZONTE_EDUCACENSO_SKIP_IF_MISSING=true
# HORIZONTE_EDUCACENSO_ALLOW_EMPTY=false
# HORIZONTE_EDUCACENSO_YEARS_PER_STEP=1
# HORIZONTE_EDUCACENSO_MEMORY_LIMIT=1024M
# Feed bimestral — tolerância a fases vazias (não bloqueia o mapa)
# HORIZONTE_FORTNIGHTLY_FUNDEB_ALLOW_EMPTY=true
# Agendamento bimestral (dia 1, meses ímpares, 03:00)
# HORIZONTE_FORTNIGHTLY_FEED_SCHEDULE_DAY=1
# HORIZONTE_FORTNIGHTLY_FEED_SCHEDULE_MONTHS=1,3,5,7,9,11
# HORIZONTE_FORTNIGHTLY_FEED_TIME=03:00
# Modo em etapas (1 fase por invocação — recomendado em produção)
# HORIZONTE_FORTNIGHTLY_FEED_STAGED=true
# HORIZONTE_FORTNIGHTLY_FEED_STEP_INTERVAL=20
# HORIZONTE_FORTNIGHTLY_FEED_NOTIFY_PHASES=true
# HORIZONTE_FORTNIGHTLY_FEED_MEMORY_LIMIT=512M
# HORIZONTE_FORTNIGHTLY_FEED_TIME_LIMIT=900
# Registo SGE (sistemas de gestão educacional) — opcional, não bloqueia o Horizonte
# HORIZONTE_SGE_ENABLED=true
# HORIZONTE_SGE_REGISTRY_PATH=horizonte/sge_registry.json
# HORIZONTE_SGE_REGISTRY_URL=
# HORIZONTE_SGE_REGISTRY_HTTP_TIMEOUT=15
# HORIZONTE_SGE_REGISTRY_CACHE_TTL=604800
# Alertas MEC/FNDE no modal municipal (horizonte:sync-municipal-alerts)
# HORIZONTE_MUNICIPAL_ALERTS_ENABLED=true
# Fonte principal: CSV oficial FNDE VAAT inabilitados (fallback: PDF)
# HORIZONTE_FNDE_VAAT_INABILITADOS_CSV_URL=https://www.gov.br/fnde/pt-br/acesso-a-informacao/acoes-e-programas/financiamento/fundeb/vaat/lista-dos-entes-habilitados-e-inabilitados-ao-vaat-2026-posicao-final-com-ajuste-de-decisao-judicial-edit-csv.csv/@@download/file
# HORIZONTE_FNDE_VAAT_INABILITADOS_PDF_URL=https://www.gov.br/fnde/pt-br/acesso-a-informacao/acoes-e-programas/financiamento/fundeb/2025-1/ListapreliminarinabilitadosVAAT202623Jun2025.pdf
# Fonte adicional: CSV oficial FNDE VAAR (entes não habilitados/não beneficiários — condicionalidades de gestão)
# HORIZONTE_FNDE_VAAR_ENABLED=true
# HORIZONTE_FNDE_VAAR_CSV_URL=https://www.gov.br/fnde/pt-br/acesso-a-informacao/acoes-e-programas/financiamento/fundeb/2026-1/ListaentesbeneficiariosenaobeneficiariosacomplementacaoVAARdoFundeb2026.csv
# Fonte adicional: XLSX oficial FNDE/PNAE entidades suspensas (actualizar URL a cada publicação)
# HORIZONTE_PNAE_SUSPENSAS_ENABLED=true
# HORIZONTE_PNAE_SUSPENSAS_XLSX_URL=https://www.gov.br/fnde/pt-br/acesso-a-informacao/acoes-e-programas/programas/pnae/consultas/entidades-suspensas-1/ENTIDADESSUSPENSAS_29_12_2025.xlsx
# HORIZONTE_MUNICIPAL_ALERTS_PATH=horizonte/municipal_alerts_registry.json

# --- CadÚnico / Cecad (agregados municipais, aba Cadastro) ---
IEDUCAR_CADUNICO_ENABLED=true
IEDUCAR_CADUNICO_IDADE_MIN=4
IEDUCAR_CADUNICO_IDADE_MAX=17
IEDUCAR_CADUNICO_COBERTURA_ALERTA_PCT=92
IEDUCAR_CADUNICO_CSV_DELIMITER=;
IEDUCAR_CADUNICO_CSV_PATH=cadunico/cecad
IEDUCAR_CADUNICO_CACHE_ENABLED=true
IEDUCAR_CADUNICO_HTTP_TIMEOUT=45
# Fonte oficial MDS/SAGI (Misocial Solr) — não requer servidor próprio
IEDUCAR_CADUNICO_MISOGIAL_ENABLED=true
# IEDUCAR_CADUNICO_MISOGIAL_BASE_URL=https://aplicacoes.mds.gov.br/sagi/servicos/misocial
# IEDUCAR_CADUNICO_MISOGIAL_PAGE_SIZE=6000
# IEDUCAR_CADUNICO_MISOGIAL_FROM_YEAR=2020
# IEDUCAR_CADUNICO_MISOGIAL_FIELDS=   # vazio = lista compacta (recomendado)
# Sincronização automática (sem upload) — CSV nacional descarregado por HTTP
IEDUCAR_CADUNICO_AUTO_SYNC_ENABLED=true
IEDUCAR_CADUNICO_SYNC_ON_CITY_SAVE=true
IEDUCAR_CADUNICO_FILL_API_GAPS=true
IEDUCAR_CADUNICO_REFRESH_CSV_DAYS=30
# Obrigatório para automação sem upload: URL do export Cecad nacional (placeholder {ano})
# Complemento se Misocial falhar (servidor próprio / export Cecad):
# IEDUCAR_CADUNICO_NACIONAL_CSV_URL=https://seu-servidor/cadunico/nacional_{ano}.csv
# IEDUCAR_CADUNICO_MUNICIPAL_CSV_URL=https://seu-servidor/cadunico/{ibge}_{ano}.csv
# IEDUCAR_CADUNICO_SYNC_YEARS=2024,2023
IEDUCAR_CADUNICO_SCHEDULE_ENABLED=true
IEDUCAR_CADUNICO_SCHEDULE_DAY=1
IEDUCAR_CADUNICO_SCHEDULE_TIME=03:30
# URL modelo JSON por município (API MDS quando disponível)
# IEDUCAR_CADUNICO_API_URL_TEMPLATE=https://exemplo.gov.br/api/cadunico/{ibge}/{ano}.json
# CKAN dados.gov.br (resource_id do conjunto agregado municipal)
# IEDUCAR_CADUNICO_CKAN_URL=https://dados.gov.br
# IEDUCAR_CADUNICO_CKAN_RESOURCE_ID=
IEDUCAR_CADUNICO_DADOS_GOV_SEARCH=true
# IEDUCAR_CADUNICO_CKAN_BASES=https://dados.gov.br,https://catalogo.dados.gov.br
# IEDUCAR_CADUNICO_CKAN_SEARCH_QUERY=cadastro unico municipio ibge
# IEDUCAR_CADUNICO_DADOS_GOV_QUERY=cadastro unico municipio

# --- Painel analítico (/dashboard/analytics) — ver docs/VARIAVEIS_AMBIENTE.md §7 ---
ANALYTICS_LAZY_TABS=true
ANALYTICS_INDEX_LIGHT_FILTERS=true
ANALYTICS_INDEX_LOAD_OVERVIEW=false
ANALYTICS_INDEX_FUNDING_CONTEXT=false
ANALYTICS_DEBUG_LOG=false
ANALYTICS_FUNDEB_DISC_SUMMARY=true
ANALYTICS_FUNDING_SUMMARY_CACHE=600
# Diagnóstico: reutilizar dados já carregados na faixa de impacto (Finanças)
ANALYTICS_MUNICIPALITY_HEALTH_REUSE_CONTEXT=true
ANALYTICS_FINANCE_TABS_REUSE_CONTEXT=true
ANALYTICS_FINANCE_TABS_STRIP_CONTEXT=true
# Diagnóstico: cache do snapshot (segundos; 0 = desligado; partilha com cache de abas)
ANALYTICS_MUNICIPALITY_HEALTH_CACHE=300
# Diagnóstico: strategic (leve, defeito) | full (completo) | progressive (shell + AJAX)
ANALYTICS_MUNICIPALITY_HEALTH_MODE=strategic
# Só em mode=strategic: activar legado shell + secções AJAX (true = 4 pedidos)
ANALYTICS_MUNICIPALITY_HEALTH_PROGRESSIVE=false
ANALYTICS_PDF_QUEUE=default
ANALYTICS_PDF_JOB_TIMEOUT=900
ANALYTICS_PDF_TRIES=2
ANALYTICS_PDF_SCHEDULE_ENABLED=true
ANALYTICS_PDF_SCHEDULE_ON_DEMAND=true
ANALYTICS_PDF_SCHEDULE_ON_DEMAND_MAX_SECONDS=900
ANALYTICS_PDF_DISK=local
ANALYTICS_PDF_MAX_PER_USER=10
ANALYTICS_PDF_SERVENTEC_NAME="Serventec Assessoria"
ANALYTICS_PDF_SERVENTEC_URL=https://analise.serventecassessoria.com.br
# ANALYTICS_PDF_SYSTEM_NAME=SERVLITCYS
# ANALYTICS_PDF_ICON_PATH=favicon.svg
ANALYTICS_PDF_REGIONAL_IMAGE=images/pdf/regional
ANALYTICS_PDF_MAP_ZOOM=10
ANALYTICS_PDF_NOMINATIM_USER_AGENT="servlitcys-pdf-cover/1.0 (contact: analise.serventecassessoria.com.br)"
# ANALYTICS_DIAGNOSTICS_FORCE=true
# ANALYTICS_DIAGNOSTICS_TOKEN=

# --- FUNDEB / discrepâncias ---
IEDUCAR_DISC_VAA_REFERENCIA=4500
IEDUCAR_FUNDEB_NATIONAL_FLOOR=true
IEDUCAR_FUNDEB_NATIONAL_VAAF_2024=
IEDUCAR_FUNDEB_NATIONAL_VAAF_2025=5559.73
IEDUCAR_FUNDEB_NATIONAL_VAAF_2026=5954.14
IEDUCAR_FUNDEB_NATIONAL_VAAT_2026=10193.74
# IEDUCAR_FUNDEB_RECEITA_CSV_URL_2025=
# IEDUCAR_FUNDEB_VAAT_CSV_URL_2025=
IEDUCAR_FUNDEB_USE_IMPORTED_VAAR=true
# IEDUCAR_FUNDEB_VAAR_PCT_BASE=0
IEDUCAR_FUNDEB_JSON_URL=storage://app/fundeb/api/{ibge}/{ano}.json
IEDUCAR_FUNDEB_CKAN_URL=https://www.fnde.gov.br/dadosabertos
IEDUCAR_FUNDEB_CKAN_RESOURCE_ID=
IEDUCAR_FUNDEB_CKAN_SEARCH="fundeb vaaf municipio"
IEDUCAR_FUNDEB_API_TIMEOUT=30
IEDUCAR_MATRICULA_INDICADORES_INCLUIR_SITUACAO_INEP=true
IEDUCAR_MATRICULA_SITUACAO_INEP_ATIVAS=1

# --- Inclusão / educação especial (consultoria) ---
# Contar matrículas em turma/curso AEE além do cadastro NEE (fisica_deficiencia / aluno_deficiencia)
IEDUCAR_INCLUSION_NEE_INCLUIR_TURMA_AEE=true

# --- Financiamentos (consultas públicas) ---
IEDUCAR_OTHER_FUNDING_PUBLIC_QUERIES=true
IEDUCAR_OTHER_FUNDING_PUBLIC_CACHE_TTL=3600
IEDUCAR_OTHER_FUNDING_PUBLIC_TIMEOUT=12
IEDUCAR_OTHER_FUNDING_LIVE_FNDE=true
PORTAL_TRANSPARENCIA_API_KEY=
IEDUCAR_PORTAL_TRANSPARENCIA_ENABLED=true
IEDUCAR_TESOURO_CKAN_ENABLED=true
IEDUCAR_TESOURO_TRANSFERENCIAS_RESOURCE_ID=
IEDUCAR_FUNDING_TRANSFERS_ENABLED=true
IEDUCAR_FUNDING_TRANSFERS_TIMEOUT=20
IEDUCAR_FUNDING_TRANSFERS_HISTORICAL_YEARS=5
# Extrato BB — download automático (ver docs/BB_EXTRATO_OPEN_FINANCE.md)
IEDUCAR_BB_EXTRATO_FUNDEB_ENABLED=true
# IEDUCAR_BB_EXTRATO_URL_TEMPLATE=https://intranet.example/export/bb/{ibge}_{ano}.csv
# IEDUCAR_BB_EXTRATO_EXPORT_URL=
IEDUCAR_BB_EXTRATO_REFRESH_DAYS=7
IEDUCAR_BB_EXTRATO_HTTP_TIMEOUT=30
# IEDUCAR_BB_EXTRATO_FUNDEB_KEYWORDS=fundeb,fnde,salario educacao,salário-educação,tesouro nacional
# Open Finance BB (UI Tempo Real; API de transações ainda não implementada)
# IEDUCAR_BB_OPEN_FINANCE_ENABLED=false
# IEDUCAR_BB_OPEN_FINANCE_CLIENT_ID=
# IEDUCAR_BB_OPEN_FINANCE_BASE_URL=https://api.bb.com.br
# IEDUCAR_DISC_CENSO_MAT_TOLERANCE_PCT=10

# --- Censo / trabalho realizado ---
IEDUCAR_WORK_EXCLUDE_LOGINS=admin,administrador,suporte,portabilis
IEDUCAR_WORK_EXCLUDE_USER_IDS=1
IEDUCAR_WORK_EXCLUDE_NIVEL=1
IEDUCAR_WORK_MINUTES_PER_RECORD=3.5
IEDUCAR_WORK_HOURS_PER_DAY=6

# --- Scheduler (cron: * * * * * php artisan schedule:run — ver docs/IMPLANTACAO_PRODUCAO.md) ---
# SCHEDULE_LOG_TO_FILE=true
# SCHEDULE_LOG_PATH=
SCHEDULE_RUN_INTERVAL_MINUTES=3

# --- Sincronização administrativa (admin-sync) ---
ADMIN_SYNC_QUEUE=admin-sync
ADMIN_PROCESSING_QUEUE_FLUSH_SLUG=zerar-fila-processamento
ADMIN_SYNC_JOB_TIMEOUT=3600
ADMIN_SYNC_TRIES=1
ADMIN_SYNC_SCHEDULE_ENABLED=true
ADMIN_SYNC_SCHEDULE_TIMES=06:00,18:00
ADMIN_SYNC_SCHEDULE_ON_DEMAND=true
ADMIN_SYNC_SCHEDULE_ON_DEMAND_MAX_SECONDS=900
ADMIN_SYNC_SCHEDULE_MAX_SECONDS=3300
ADMIN_SYNC_SCHEDULE_OVERLAP_MINUTES=720
# Legado (só se ADMIN_SYNC_SCHEDULE_TIMES estiver vazio):
# ADMIN_SYNC_SCHEDULE_INTERVAL_MINUTES=60

# --- Sincronização massiva semanal (weekly-mass-sync:run) ---
IEDUCAR_WEEKLY_MASS_SYNC_ENABLED=true
IEDUCAR_WEEKLY_MASS_SYNC_SCHEDULE_ENABLED=true
IEDUCAR_WEEKLY_MASS_SYNC_DAY=0
IEDUCAR_WEEKLY_MASS_SYNC_TIME=02:00
IEDUCAR_WEEKLY_MASS_SYNC_JOB_TIMEOUT=14400
IEDUCAR_WEEKLY_MASS_SYNC_WORKER_MAX_SECONDS=14400
IEDUCAR_WEEKLY_MASS_SYNC_PHP_TIME_LIMIT=14400
IEDUCAR_WEEKLY_MASS_SYNC_TRANSFER_YEARS=3
IEDUCAR_WEEKLY_MASS_SYNC_PHASE_GEO=true
IEDUCAR_WEEKLY_MASS_SYNC_PHASE_FUNDEB=true
IEDUCAR_WEEKLY_MASS_SYNC_PHASE_TRANSFERS=true
IEDUCAR_WEEKLY_MASS_SYNC_PHASE_CENSO=true
IEDUCAR_WEEKLY_MASS_SYNC_PHASE_SAEB=true
IEDUCAR_WEEKLY_MASS_SYNC_PHASE_CENSO_AGG=true

# --- Laravel Pulse ---
PULSE_ENABLED=true
PULSE_PATH=pulse
PULSE_STORAGE_DRIVER=database
PULSE_DB_CONNECTION=mysql
PULSE_INGEST_DRIVER=storage
PULSE_SCHEDULE_ENABLED=true
PULSE_SCHEDULE_INTERVAL_MINUTES=3
PULSE_SCHEDULE_DIGEST_TICK=true
PULSE_SLOW_QUERIES_THRESHOLD=500
PULSE_SLOW_REQUESTS_THRESHOLD=1000
PULSE_SLOW_OUTGOING_REQUESTS_THRESHOLD=750
PULSE_SLOW_JOBS_THRESHOLD=1000
PULSE_SERVER_NAME=
PULSE_SERVER_DIRECTORIES=/

# --- i-Educar — schema/tabelas (só se divergir do Portabilis) ---
# Frequência (aba Analytics): php artisan ieducar:probe-falta {city_id}
# IEDUCAR_TABLE_FALTA_ALUNO=falta_aluno
# IEDUCAR_COL_FALTA_MATRICULA=ref_cod_matricula
# IEDUCAR_COL_FALTA_DATA=data_falta
# IEDUCAR_SCHEMA=
# IEDUCAR_PGSQL_SEARCH_PATH=pmieducar,cadastro,public,relatorio

# URL pública do i-Educar por município (botão no mapa do Início; prioridade: cadastro da cidade)
# IEDUCAR_APP_URLS={"1":"https://itamari.exemplo.gov.br","5":"https://saubara.exemplo.gov.br"}
# IEDUCAR_APP_URL_TEMPLATE=https://{slug}.ieducar.exemplo.gov.br

# --- SAEB / INEP ---
IEDUCAR_SAEB_SERIES_ENABLED=true
IEDUCAR_SAEB_OFFICIAL_USE_INTERNAL=true
IEDUCAR_SAEB_OFFICIAL_AUTO_MICRODADOS=true
IEDUCAR_SAEB_OFFICIAL_RESOLVE_INEP=true
IEDUCAR_SAEB_MICRODADOS_ENABLED=true
IEDUCAR_SAEB_MICRODADOS_ZIP_URL=https://download.inep.gov.br/microdados/microdados_saeb_{year}.zip
# Microdados 2021: URL específica em config/ieducar.php (microdados_saeb_2021_ensino_fundamental_e_medio.zip).
# Planilhas oficiais INEP (CO_MUNICIPIO IBGE) — comando: php artisan saeb:import-planilhas-inep --years=2021,2023
# URLs em config/ieducar.php → saeb.planilha_resultados_urls (2023 RAR, 2021 XLSX)
# IEDUCAR_SAEB_PLANILHA_CACHE_PATH=saeb/planilhas
# IEDUCAR_SAEB_PLANILHA_DEPENDENCIA=Municipal
# IEDUCAR_SAEB_OPENDATA_CSV_URL=   (CSV directo; não aceita XLSX/RAR)
IEDUCAR_SAEB_HTTP_VERIFY=true
IEDUCAR_INEP_GEOCODING_ENABLED=true

# --- Desenvolvimento local (descomente no .env local) ---
# APP_ENV=local
# APP_DEBUG=true
# LOG_LEVEL=debug
# ANALYTICS_DEBUG_LOG=true
# SESSION_ENCRYPT=false
# SESSION_SECURE_COOKIE=false
# MAIL_MAILER=log

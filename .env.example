APP_NAME=servlitcys
APP_ENV=local
APP_KEY=
APP_DEBUG=true
APP_URL=http://localhost

APP_LOCALE=pt_BR
APP_FALLBACK_LOCALE=en
APP_FAKER_LOCALE=en_US

APP_MAINTENANCE_DRIVER=file
# APP_MAINTENANCE_STORE=database

# PHP_CLI_SERVER_WORKERS=4

BCRYPT_ROUNDS=12

LOG_CHANNEL=stack
LOG_STACK=single
LOG_DEPRECATIONS_CHANNEL=null
LOG_LEVEL=debug

# Base de dados principal da aplicação (Laravel: utilizadores, cidades, sessões, filas)
DB_CONNECTION=mysql
DB_HOST=127.0.0.1
DB_PORT=3306
DB_DATABASE=servlitcys
DB_USERNAME=root
DB_PASSWORD=

# Opcional: URL em vez das variáveis acima
# DB_URL=mysql://usuario:senha@127.0.0.1:3306/servlitcys

# Credenciais do utilizador administrador criado pelo AdminUserSeeder — definir antes do seed (nunca usar valor de exemplo em produção)
ADMIN_EMAIL=admin@servlitcys.local
ADMIN_USERNAME=admin
ADMIN_PASSWORD=ChangeMeStrongPassword1!
# Data de nascimento (Y-m-d) — usada na recuperação de palavra-passe em conjunto com o e-mail
ADMIN_BIRTH_DATE=1990-01-01

# WhatsApp atendimento Serventec (só dígitos com DDI, ex.: 5511999998888). Vazio = botão preparado sem destino.
# SERVENTEC_WHATSAPP_NUMBER=

# Mapeamento iEducar (ver config/ieducar.php). Por cidade PostgreSQL sem campo no cadastro,
# usa-se pmieducar por defeito (IEDUCAR_PGSQL_DEFAULT_SCHEMA).
# IEDUCAR_SCHEMA=
# IEDUCAR_PGSQL_DEFAULT_SCHEMA=pmieducar
# IEDUCAR_PGSQL_SEARCH_PATH=pmieducar,cadastro,public
# IEDUCAR_TABLE_ESCOLA=escola
# IEDUCAR_TABLE_MATRICULA=matricula
# Turno (PostgreSQL Portabilis): por defeito cadastro.turno; em MySQL usa-se o nome curto (turno)
# IEDUCAR_TABLE_TURNO=cadastro.turno
# IEDUCAR_MYSQL_TABLE_TURNO=
# IEDUCAR_COL_TURNO_ID=cod_turno
# IEDUCAR_COL_TURNO_NAME=nome
# Inclusão / diversidade (cadastro Portabilis — ajuste nomes se necessário)
# IEDUCAR_TABLE_ALUNO=aluno
# IEDUCAR_TABLE_PESSOA=cadastro.pessoa
# IEDUCAR_TABLE_RACA=cadastro.raca
# IEDUCAR_SQL_INCLUSION_RACA=
# IEDUCAR_SQL_INCLUSION_EXTRA=
# IEDUCAR_CHART_COLORS=#6366f1,#22c55e,#f59e0b,#ec4899,#06b6d4,#a855f7
# IEDUCAR_MAX_ROWS=2000

SESSION_DRIVER=database
SESSION_LIFETIME=120
SESSION_ENCRYPT=false
SESSION_PATH=/
SESSION_DOMAIN=null

BROADCAST_CONNECTION=log
FILESYSTEM_DISK=local
QUEUE_CONNECTION=database

CACHE_STORE=database
# CACHE_PREFIX=

MEMCACHED_HOST=127.0.0.1

REDIS_CLIENT=phpredis
REDIS_HOST=127.0.0.1
REDIS_PASSWORD=null
REDIS_PORT=6379

MAIL_MAILER=log
MAIL_SCHEME=null
MAIL_HOST=127.0.0.1
MAIL_PORT=2525
MAIL_USERNAME=null
MAIL_PASSWORD=null
MAIL_FROM_ADDRESS="hello@example.com"
MAIL_FROM_NAME="${APP_NAME}"

AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
AWS_DEFAULT_REGION=us-east-1
AWS_BUCKET=
AWS_USE_PATH_STYLE_ENDPOINT=false

VITE_APP_NAME="${APP_NAME}"

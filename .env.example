APP_NAME=servlitcys
APP_ENV=local
APP_KEY=
APP_DEBUG=true
APP_URL=http://localhost

# Texto opcional no rodapé das exportações PNG/PDF dos gráficos (ex.: equipa ou secretaria)
CHART_EXPORT_AUTHOR=

APP_LOCALE=pt_BR
APP_FALLBACK_LOCALE=en
APP_FAKER_LOCALE=en_US

APP_MAINTENANCE_DRIVER=file
# APP_MAINTENANCE_STORE=database

# PHP_CLI_SERVER_WORKERS=4

BCRYPT_ROUNDS=12

LOG_CHANNEL=stack
LOG_STACK=single
LOG_DEPRECATIONS_CHANNEL=null
LOG_LEVEL=debug

# Base de dados principal da aplicação (Laravel: utilizadores, cidades, sessões, filas)
DB_CONNECTION=mysql
DB_HOST=127.0.0.1
DB_PORT=3306
DB_DATABASE=servlitcys
DB_USERNAME=root
DB_PASSWORD=

# Opcional: URL em vez das variáveis acima
# DB_URL=mysql://usuario:senha@127.0.0.1:3306/servlitcys

# Credenciais do utilizador administrador criado pelo AdminUserSeeder — definir antes do seed (nunca usar valor de exemplo em produção)
ADMIN_EMAIL=admin@servlitcys.local
ADMIN_USERNAME=admin
ADMIN_PASSWORD=ChangeMeStrongPassword1!
# Data de nascimento (Y-m-d) e CPF (11 dígitos, sem máscara) — usados na recuperação de palavra-passe
ADMIN_BIRTH_DATE=1990-01-01
ADMIN_CPF=11144477735

# WhatsApp atendimento Serventec (só dígitos com DDI, ex.: 5511999998888). Vazio = botão preparado sem destino.
# SERVENTEC_WHATSAPP_NUMBER=

# --- iEducar / PostgreSQL: schemas dinâmicos (ver config/ieducar.php) ---
# Schema global (.env); por cidade pode sobrescrever em cities.ieducar_schema (admin).
# IEDUCAR_SCHEMA=
# Se vazio, usa IEDUCAR_PGSQL_DEFAULT_SCHEMA (típico pmieducar) para prefixar tabelas sem schema em IEDUCAR_TABLE_*.
# IEDUCAR_PGSQL_DEFAULT_SCHEMA=pmieducar
# Ordem do search_path na ligação city_data_* (principal primeiro; inclua relatorio se usar funções relatorio.*).
# IEDUCAR_PGSQL_SEARCH_PATH=pmieducar,cadastro,public,relatorio
# Nomes para placeholders {cadastro}, {relatorio}, {modules} em IEDUCAR_SQL_* (bases não padrão).
# IEDUCAR_PGSQL_SCHEMA_CADASTRO=cadastro
# IEDUCAR_PGSQL_SCHEMA_RELATORIO=relatorio
# IEDUCAR_PGSQL_SCHEMA_MODULES=modules
# IEDUCAR_TABLE_ESCOLA=escola
# IEDUCAR_TABLE_MATRICULA=matricula
# Pivô matrícula↔turma (PostgreSQL; quando matricula não tem ref_cod_turma)
# IEDUCAR_TABLE_MATRICULA_TURMA=matricula_turma
# IEDUCAR_COL_MATRICULA_TURMA_MATRICULA=ref_cod_matricula
# IEDUCAR_COL_MATRICULA_TURMA_TURMA=ref_cod_turma
# IEDUCAR_COL_MATRICULA_TURMA_ATIVO=ativo
# Turno (PostgreSQL Portabilis): por defeito cadastro.turno; em MySQL usa-se o nome curto (turno)
# IEDUCAR_TABLE_TURNO=cadastro.turno
# Tabelas extra a tentar se a principal falhar (separadas por vírgula), ex.: modules.turno,public.turno
# IEDUCAR_TABLE_TURNO_FALLBACKS=
# IEDUCAR_MYSQL_TABLE_TURNO=
# IEDUCAR_COL_TURNO_ID=cod_turno
# IEDUCAR_COL_TURNO_NAME=nome
# Inclusão / diversidade (cadastro Portabilis — ajuste nomes se necessário)
# IEDUCAR_TABLE_ALUNO=aluno
# IEDUCAR_TABLE_PESSOA=cadastro.pessoa
# IEDUCAR_TABLE_RACA=cadastro.raca
# Tabelas extra para raça/cor (PostgreSQL), ex.: public.raca
# IEDUCAR_TABLE_RACA_FALLBACKS=
# Ordenação da série (INEP / ano da etapa) para gráficos «turma por etapa»
# IEDUCAR_COL_SERIE_SORT=serie
# IEDUCAR_COL_SERIE_ETAPA_EDUCACENSO=etapa_educacenso
# Curso → nível de ensino (hierarquia Educacenso no painel de matrículas)
# IEDUCAR_COL_CURSO_NIVEL=ref_cod_nivel_ensino
# Capacidade da turma (vagas em aberto = max_aluno − matrículas)
# IEDUCAR_COL_TURMA_MAX_ALUNO=max_aluno
# Desempenho (campo na tabela matricula — por defeito aprovado)
# IEDUCAR_COL_MATRICULA_APROVADO=aprovado
# Frequência (faltas)
# IEDUCAR_TABLE_FALTA_ALUNO=falta_aluno
# IEDUCAR_COL_FALTA_MATRICULA=ref_cod_matricula
# IEDUCAR_COL_FALTA_DATA=data_falta
# SQL customizado: placeholders {escola},{curso},{turno},{turma},{matricula},{matricula_turma},{ano_letivo},{serie},
# {aluno},{pessoa},{raca},{falta_aluno}, {schema}/{schema_main}, {cadastro}, {relatorio}, {modules}, {public}
# IEDUCAR_SQL_ANO_LETIVO=SELECT DISTINCT ano FROM {ano_letivo} WHERE ano IS NOT NULL ORDER BY ano DESC
# IEDUCAR_SQL_ESCOLA=SELECT cod_escola AS id, relatorio.get_nome_escola(cod_escola) AS nome FROM {escola} WHERE ativo = 1 ORDER BY nome
# IEDUCAR_SQL_TURNO=SELECT cod_turno AS id, nome AS nome FROM {turno} ORDER BY nome
# IEDUCAR_SQL_INCLUSION_RACA=
# IEDUCAR_SQL_INCLUSION_EXTRA=
# Índice ou % de distorção idade/série (rede); uma linha com valor numérico. Ex.: SELECT 15.2 AS percentual
# IEDUCAR_SQL_DISTORCAO_REDE=
# IDEB/SAEB/PNE (uma linha por indicador): ver config/ieducar.php
# IEDUCAR_SQL_PERFORMANCE_INEP=
# SAEB — gráficos Desempenho leem só o JSON importado (Admin → Sincronizações → Pedagógicas)
# IEDUCAR_SAEB_SERIES_ENABLED=true
# IEDUCAR_SAEB_JSON_PATH=saeb/historico.json
# Importação oficial: uma URL por município com placeholders {ibge} (7 dígitos), {uf}, {city_id}
# Opcional. Se vazio, usa APP_URL + /api/saeb/municipio/{ibge}.json (requer APP_URL=https://domínio público)
# IEDUCAR_SAEB_OFFICIAL_URL_TEMPLATE=
# Antes do HTTP: ler ficheiros em storage (saeb/municipio/{ibge}.json ou historico.json)
# IEDUCAR_SAEB_OFFICIAL_USE_INTERNAL=true
# IEDUCAR_SAEB_OFFICIAL_TIMEOUT=60
# Gravar ficheiros storage/app/public/saeb/municipio/{ibge}.json após importação; expor GET /api/saeb/municipio/{ibge}
# IEDUCAR_SAEB_MUNICIPIO_JSON_FILES=true
# IEDUCAR_SAEB_PUBLIC_API=true
# URL(s) opcionais com JSON completo «pontos» (separadas por vírgula). Sem fallback para ficheiros de exemplo.
# IEDUCAR_SAEB_IMPORT_URLS=
# IEDUCAR_SAEB_IMPORT_TIMEOUT=45
# Timeout por tentativa HTTP (várias URLs em sequência)
# IEDUCAR_SAEB_IMPORT_ATTEMPT_TIMEOUT=12
# IEDUCAR_PGSQL_USE_RELATORIO_ESCOLA_NOME=true
# IEDUCAR_PGSQL_USE_RAW_TURNO_SQL=true
# IEDUCAR_CHART_COLORS=#6366f1,#22c55e,#f59e0b,#ec4899,#06b6d4,#a855f7
# Georreferenciação INEP (Catálogo de Escolas — ArcGIS) quando não há lat/lng na escola
# IEDUCAR_INEP_GEOCODING_ENABLED=true
# Uma URL ou várias separadas por vírgula (segunda camada = fallback nacional/regional quando a primeira não tem o INEP)
# IEDUCAR_INEP_ARCGIS_QUERY_URLS=https://services3.arcgis.com/ba17q0p2zHwzRK3B/arcgis/rest/services/inep_escolas_fmt_250609_geocode/FeatureServer/1/query
# IEDUCAR_INEP_ARCGIS_QUERY_URL=https://services3.arcgis.com/ba17q0p2zHwzRK3B/arcgis/rest/services/inep_escolas_fmt_250609_geocode/FeatureServer/1/query
# Enriquecer cartão do mapa com endereço/telefone do catálogo mesmo se IEDUCAR_INEP_GEOCODING_ENABLED=false
# IEDUCAR_INEP_ENRICH_MAP_MARKERS=true
# IEDUCAR_QEDU_ESCOLA_BASE_URL=https://www.qedu.org.br/escola
# URL público INEP por escola (Portal IDEB); use {inep} para o código. Sem {inep} = mesma página para todas.
# IEDUCAR_INEP_PORTAL_ESCOLA_URL_TEMPLATE=https://www.portalideb.org.br/resultado/escola/{inep}
# IEDUCAR_INEP_GEO_CACHE_TTL=2592000
# IEDUCAR_INEP_GEO_BATCH_SIZE=40
# Reutilizar coordenadas já gravadas em school_unit_geos (mesmo INEP, outra sincronização)
# IEDUCAR_INEP_GEO_SCHOOL_UNIT_GEO_FALLBACK=true
# CSV manual de fallback (runtime / import legado): IEDUCAR_INEP_GEO_FALLBACK_CSV=inep_geo_fallback.csv
# Microdados Censo (último passo do pipeline; storage/app/public/inep): glob escolhe o ano mais recente
# IEDUCAR_INEP_MICRODADOS_CADASTRO_ESCOLAS=inep/microdados_ed_basica_*.csv
# Descarregar ZIP oficial do INEP se o CSV não existir (admin/pipeline)
# IEDUCAR_INEP_MICRODADOS_FETCH=true
# IEDUCAR_INEP_MICRODADOS_DOWNLOAD_URL=http://download.inep.gov.br/dados_abertos/microdados_censo_escolar_{year}.zip
# IEDUCAR_INEP_MICRODADOS_YEAR=
# Lookup no mapa a partir do CSV local (só se existirem colunas lat/lng)
# IEDUCAR_INEP_MICRODADOS_RUNTIME_LOOKUP=true
# Modal do mapa: município/UF/região (Censo) quando não há endereço no i-Educar (requer app:index-inep-censo-geo-agg ou import com índice ativo)
# IEDUCAR_INEP_CENSO_GEO_AGG_MODAL=true
# Após app:import-inep-microdados-cadastro-escolas-geo, reindexar geo agregada (truncate + CSV completo; pode demorar)
# IEDUCAR_INEP_CENSO_GEO_AGG_INDEX_ON_IMPORT=true
# IEDUCAR_MAX_ROWS=2000

SESSION_DRIVER=database
SESSION_LIFETIME=120
SESSION_ENCRYPT=false
SESSION_PATH=/
SESSION_DOMAIN=null

BROADCAST_CONNECTION=log
FILESYSTEM_DISK=local
QUEUE_CONNECTION=database

CACHE_STORE=database
# CACHE_PREFIX=
# Pulse: em config/cache.php use serializable_classes null (nunca false) para o dashboard Livewire.

MEMCACHED_HOST=127.0.0.1

REDIS_CLIENT=predis
REDIS_HOST=127.0.0.1
REDIS_PASSWORD=null
REDIS_PORT=6379

MAIL_MAILER=log
MAIL_SCHEME=null
MAIL_HOST=127.0.0.1
MAIL_PORT=2525
MAIL_USERNAME=null
MAIL_PASSWORD=null
MAIL_FROM_ADDRESS="hello@example.com"
MAIL_FROM_NAME="${APP_NAME}"

AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
AWS_DEFAULT_REGION=us-east-1
AWS_BUCKET=
AWS_USE_PATH_STYLE_ENDPOINT=false

VITE_APP_NAME="${APP_NAME}"

# --- Laravel Pulse (monitorização; /pulse; só administradores na app) ---
# PULSE_ENABLED=true
# PULSE_PATH=pulse
# PULSE_STORAGE_DRIVER=database
# PULSE_DB_CONNECTION=mysql
# Consultas lentas e HTTP externos (ArcGIS INEP, etc.) — ajuste em produção
# PULSE_SLOW_QUERIES_THRESHOLD=500
# PULSE_SLOW_OUTGOING_REQUESTS_THRESHOLD=750
# Agendador (evita `pulse:check` sem --once no cron — multiplicava processos):
# PULSE_SCHEDULE_ENABLED=true
# PULSE_SCHEDULE_INTERVAL_MINUTES=5
# Se já corre `php artisan pulse:work` em Supervisor, desative o digest agendado:
# PULSE_SCHEDULE_DIGEST_TICK=false
# Opcional: um daemon contínuo (alternativa ao digest acima): `php artisan pulse:work` em Supervisor
